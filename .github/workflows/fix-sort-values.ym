name: Fix sort values

on:
  workflow_dispatch:

jobs:
  fix:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Run fix script
        run: node fix_sort.js

      - name: Commit
        run: |
          git config user.name "github-actions"
          git config user.email "actions@github.com"
          git add app.js
          git diff --staged --quiet || git commit -m "fix: sector sort + computed pos/neg"
          git push
